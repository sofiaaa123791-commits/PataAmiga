#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://gestionaspirante.localhost/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false
app.defaultLocale = es

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = prueba
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = hex2bin:f1801a1ef9efcf3d3a5bced829e194fa7013ea2e4825f1e588472ced70244f73
#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = CodeIgniter\Session\Handlers\FileHandler
session.savePath = 'C:\xampp\htdocs\project-root\writable\session'
session.matchIP = false
session.timeToUpdate = 300

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
security.csrfProtection = true
security.tokenRandomize = true

#--------------------------------------------------------------------
# COOKIE
#--------------------------------------------------------------------
cookie.secure = false
cookie.httponly = true
cookie.samesite = Lax

#--------------------------------------------------------------------
# AUTH (Shield)
#--------------------------------------------------------------------
auth.session.enabled = true
auth.remember.enabled = true
auth.allowRegistration = true
auth.allowRemembering = true

#--------------------------------------------------------------------
# EMAIL (opcional para recuperación de contraseña)
#--------------------------------------------------------------------
email.fromEmail = "no-reply@localhost"
email.fromName = "Mi App"
email.protocol = smtp
email.SMTPHost = localhost
email.SMTPUser =
email.SMTPPass =
email.SMTPPort = 587
email.SMTPTimeout = 5
email.mailType = html